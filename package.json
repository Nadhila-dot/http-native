{
  "name": "@http-native/core",
  "version": "0.0.13",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Http-native/http-native.git"
  },
  "bin": {
    "http-native": "./src/cli.js"
  },
  "files": [
    "src",
    "scripts/ensure-native.mjs",
    "scripts/setup-native.mjs",
    "scripts/native"
  ],
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./cors": "./src/cors.js",
    "./dev": {
      "types": "./src/dev/index.d.ts",
      "default": "./src/dev/index.js"
    },
    "./hot": "./src/hot.js",
    "./session": "./src/session.js",
    "./validate": "./src/validate.js",
    "./http-server.config": "./src/http-server.config.js"
  },
  "scripts": {
    "build": "bun scripts/build-native.mjs",
    "build:release": "bun scripts/build-native.mjs --release",
    "dev": "bun src/cli.js dev",
    "postinstall": "bun scripts/ensure-native.mjs || node scripts/ensure-native.mjs",
    "setup:native": "bun scripts/setup-native.mjs || node scripts/setup-native.mjs",
    "test": "bun run build && bun .github/tests/test.js && bun .github/tests/test-dev.js"
  },
  "devDependencies": {
    "express": "^5.1.0"
  }
}
